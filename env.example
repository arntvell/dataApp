# Database
DATABASE_URL=postgresql://dataapp:password@localhost:5432/dataapp

# Redis
REDIS_URL=redis://localhost:6379

# Sitoo
SITOO_BASE_URL=https://api140.mysitoo.com/v2/accounts/91622/
SITOO_API_ID=91622-174
SITOO_API_KEY=your_sitoo_api_key_here

# Shopify
SHOPIFY_BASE_URL=https://your-store.myshopify.com
SHOPIFY_API_KEY=your_shopify_access_token_here

# SameSystem
SAMESYSTEM_EMAIL=your_email@example.com
SAMESYSTEM_PASSWORD=your_password_here
SAMESYSTEM_DEPARTMENTS={"Store Name": "ctx_token_from_url"}

# Cin7 Core
CIN7_ACCOUNT_ID=your_cin7_account_id
CIN7_API_KEY=your_cin7_api_key

# Scheduler (set to true to enable automatic sync jobs)
SCHEDULER_ENABLED=false

# Auth (HTTP Basic). Auth is enabled only when APP_PASSWORD is set.
# Admin login = full access (dashboard + everything).
APP_USERNAME=livid
APP_PASSWORD=
# Optional store-manager login: /store page + read-only stock & sale-list only,
# no admin dashboard. Enabled only when STORE_PASSWORD is set.
STORE_USERNAME=store
STORE_PASSWORD=

